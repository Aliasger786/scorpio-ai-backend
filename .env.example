# Django Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
# For local development (MySQL)
DB_NAME=aura_ai
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=localhost
DB_PORT=3306

# For Railway deployment (PostgreSQL - will be set automatically)
# DATABASE_URL=postgresql://user:password@host:port/database

# Django Configuration
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here

# CORS Configuration (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourbrandai.com

# Railway Configuration (will be set automatically)
# PORT=8000
# RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
# RAILWAY_STATIC_URL=https://your-app.railway.app
